APCA_API_KEY_ID=
APCA_API_SECRET_KEY=
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.5
# Required for SEC research and production readiness. Replace the placeholder with a monitored address.
SEC_USER_AGENT=ai-broker-v2 your-email@example.com
# Optional: enables FRED rate and yield-curve observations (32 lowercase alphanumeric characters).
FRED_API_KEY=
# Optional: enables BEA quarterly real-GDP observations (36-character API UserID).
BEA_USER_ID=
# Optional: enables free-tier Finnhub profile, earnings-surprise and company-news enrichment.
FINNHUB_API_KEY=
# Optional: raises OpenFIGI v3 mapping limits; anonymous public mapping remains enabled.
OPENFIGI_API_KEY=
PREVIEW_SECRET=replace-with-at-least-32-random-characters
# Production only: verified headers from a managed OIDC identity-aware proxy.
APP_ORIGIN=
AUTHORIZED_EMAIL_DOMAIN=
AUTH_PROXY_SECRET=
