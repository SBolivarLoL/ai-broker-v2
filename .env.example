# Required: Alpaca paper Trading API credentials.
APCA_API_KEY_ID=
APCA_API_SECRET_KEY=

# Required for signed order previews and readiness. Use at least 32 random characters.
PREVIEW_SECRET=replace-with-at-least-32-random-characters

# Required for SEC research and readiness. Use a real monitored contact, not this placeholder.
SEC_USER_AGENT=ai-broker-v2 your-email@example.com

# Optional AI Advisor and generated company research.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.5

# Optional research providers.
# FRED keys are 32 lowercase alphanumeric characters.
FRED_API_KEY=
# BEA UserIDs are 36 characters.
BEA_USER_ID=
FINNHUB_API_KEY=
# Anonymous OpenFIGI mapping works without a key; a key raises limits.
OPENFIGI_API_KEY=

# Optional local runtime settings.
# Unset NODE_ENV means production-strict auth; "development" enables the demo identity.
NODE_ENV=development
PORT=3000
PORTFOLIO_BENCHMARK=SPY
STRATEGY_SCHEDULER_DISABLED=0
STRATEGY_SCHEDULER_POLL_MS=60000
# Read-only market/account/order reconciliation. Polls every 15 minutes by default;
# configured intervals below 60 seconds are ignored.
RECONCILIATION_DISABLED=0
RECONCILIATION_POLL_MS=900000

# Optional deployed-build identity. Local source checkouts resolve this from Git.
# APP_GIT_COMMIT must be the full 40-character commit; dirty builds cannot seed comparable runs.
APP_GIT_COMMIT=
APP_GIT_DIRTY=0

# Production only. Leave NODE_ENV unset (or non-development) for strict auth; the
# managed proxy must strip and overwrite the trusted headers.
APP_ORIGIN=
AUTHORIZED_EMAIL_DOMAIN=
AUTH_PROXY_SECRET=
AUTH_PROXY_ROLES_HEADER=x-auth-request-roles
AUTHORIZED_ADMIN_EMAILS=
SECRET_VAULT_KEY=

# Governance-report evidence only. These do not create or enable a live broker client.
LIVE_TRADING_ENABLED=false
LIVE_TRADING_REVIEW_ID=
